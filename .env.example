APP_ENV=development
POSTGRES_DB=opengraphrag
POSTGRES_USER=opengraphrag
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql+asyncpg://opengraphrag:change-me-postgres@postgres:5432/opengraphrag
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=change-me-admin-api-key
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=opengraphrag
S3_SECRET_KEY=change-me-s3-secret
S3_BUCKET=opengraphrag
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
QDRANT_URL=http://qdrant:6333
NEO4J_URL=http://neo4j:7474
NEO4J_AUTH=neo4j/change-me-neo4j
READINESS_TIMEOUT_SECONDS=2
WEB_PORT=3000
CADDY_SITE_ADDRESS=:80
GHCR_NAMESPACE=ardiannurcahya
IMAGE_TAG=latest
WORKER_CONCURRENCY=1
