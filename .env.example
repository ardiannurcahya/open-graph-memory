APP_ENV=development
POSTGRES_DB=opengraphrag
POSTGRES_USER=opengraphrag
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql+asyncpg://opengraphrag:change-me-postgres@postgres:5432/opengraphrag
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=change-me-admin-api-key
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=opengraphrag
S3_SECRET_KEY=change-me-s3-secret
S3_BUCKET=opengraphrag
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# For external S3-compatible storage, set endpoint/credentials/region above and use
# deployments/docker-compose.external-s3.yml. Typical cloud providers need false.
# Offline/reproducible defaults. Set both providers to openai for an OpenAI-compatible API.
EMBEDDING_PROVIDER=deterministic
CHAT_PROVIDER=deterministic
EMBEDDING_MODEL=deterministic-embedding-v1
CHAT_MODEL=deterministic-chat-v1
PROVIDER_VERSION=v1
EMBEDDING_DIMENSIONS=64
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_BASE_URL=
OPENAI_CHAT_BASE_URL=
OPENAI_GRAPH_EXTRACTOR_BASE_URL=
OPENAI_API_KEY=
# OPENAI-compatible endpoints may point to different local/cloud providers. See
# docs/service-configuration.md. Current runtime shares OPENAI_API_KEY across embedding,
# chat, and graph extraction; confirm exact endpoint shapes and embedding dimensions.
GRAPH_EXTRACTOR_TIMEOUT_SECONDS=300
GRAPH_EXTRACTOR_PARALLELISM=1
COMMUNITY_REPORT_PROVIDER=
COMMUNITY_REPORT_MODEL=
COMMUNITY_REPORT_VERSION=community-report-v1
COMMUNITY_REPORT_PROMPT_VERSION=community-report-v1
COMMUNITY_REPORT_MAX_MEMBERS=100
COMMUNITY_REPORT_MAX_RELATIONS=200
COMMUNITY_REPORT_MAX_CHUNKS=20
COMMUNITY_REPORT_TIMEOUT_SECONDS=300
COMMUNITY_REPORT_LEASE_SECONDS=300
COMMUNITY_REPORT_MAX_ATTEMPTS=5
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=opengraphrag_chunks
NEO4J_URL=http://neo4j:7474
NEO4J_AUTH=neo4j/change-me-neo4j
READINESS_TIMEOUT_SECONDS=2
WEB_PORT=3000
CADDY_SITE_ADDRESS=:80
GHCR_NAMESPACE=ardiannurcahya
# Set immutable release tag or sha-<commit>; never use latest in production.
IMAGE_TAG=sha-replace-with-commit
WORKER_CONCURRENCY=1
GRAPH_WORKER_CONCURRENCY=1
GRAPH_WORKER_REPLICAS=1
