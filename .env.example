APP_ENV=development
POSTGRES_DB=opengraphrag
POSTGRES_USER=opengraphrag
POSTGRES_PASSWORD=change-me-postgres
DATABASE_URL=postgresql+asyncpg://opengraphrag:change-me-postgres@postgres:5432/opengraphrag
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=change-me-admin-api-key
S3_ENDPOINT_URL=http://rustfs:9000
S3_ACCESS_KEY=opengraphrag
S3_SECRET_KEY=change-me-s3-secret
S3_BUCKET=opengraphrag
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
PDF_PARSER=pypdf
LITEPARSE_OCR_MODE=auto
LITEPARSE_DPI=150
LITEPARSE_MAX_PAGES=300
LITEPARSE_OCR_WORKERS=1
LITEPARSE_IMAGE_MODE=off
# For external S3-compatible storage, set endpoint/credentials/region above and use
# deployments/docker-compose.external-s3.yml. Typical cloud providers need false.
# Offline/reproducible graph extraction default.
GRAPH_EXTRACTOR_PROVIDER=deterministic
GRAPH_EXTRACTOR_MODEL=deterministic-graph-v1
GRAPH_EXTRACTOR_VERSION=graph-extractor-v1
GRAPH_EXTRACTOR_PROMPT_VERSION=graph-v1
PROVIDER_VERSION=v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_GRAPH_EXTRACTOR_BASE_URL=
OPENAI_API_KEY=
# Set GRAPH_EXTRACTOR_PROVIDER=openai for a compatible extraction endpoint.
# Set GRAPH_EXTRACTOR_PROVIDER=nlp for local explicit sentence-pattern extraction.
# See docs/service-configuration.md for production requirements.
GRAPH_EXTRACTOR_TIMEOUT_SECONDS=300
GRAPH_EXTRACTOR_PARALLELISM=1
GRAPH_DOCUMENT_CONTEXT_EXCERPT_CHARS=500
GRAPH_DOCUMENT_CONSOLIDATION_ENABLED=false
GRAPH_DOCUMENT_CONSOLIDATION_VERSION=graph-consolidation-v1
GRAPH_DOCUMENT_CONSOLIDATION_PROMPT_VERSION=graph-consolidation-prompt-v1
GRAPH_DOCUMENT_CONSOLIDATION_MAX_CHARS=100000
NEO4J_URL=http://neo4j:7474
NEO4J_AUTH=neo4j/change-me-neo4j
READINESS_TIMEOUT_SECONDS=2
WEB_PORT=3000
CADDY_SITE_ADDRESS=:80
GHCR_NAMESPACE=ardiannurcahya
# Set immutable release tag or sha-<commit> in production.
IMAGE_TAG=latest
WORKER_CONCURRENCY=1
GRAPH_WORKER_CONCURRENCY=1
GRAPH_WORKER_REPLICAS=1
